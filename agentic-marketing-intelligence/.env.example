# ==============================================================
# Environment Configuration Template
# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to version control.
# ==============================================================

# --- Application ---
APP_NAME=Agentic AI Marketing Intelligence Platform
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketing_intelligence
DB_USER=postgres
DB_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/marketing_intelligence

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=2048

# --- Data Paths ---
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_EXPORTS_PATH=data/exports

# --- MLOps ---
MODEL_REGISTRY_PATH=mlops/model_registry
MLFLOW_TRACKING_URI=mlops/mlruns

# --- Security ---
SECRET_KEY=change_this_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60
