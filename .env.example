# Database
DATABASE_URL=postgresql://marketing_user:marketing_pass@localhost:5432/marketing_db

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
SECRET_KEY=change_this_to_a_random_secret_key

# Streamlit
STREAMLIT_PORT=8501

# MLOps
MLOPS_MODEL_DIR=mlops/model_registry
MLOPS_EXPERIMENT_TRACKING=true

# Data
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EXPORTS_DIR=data/exports
